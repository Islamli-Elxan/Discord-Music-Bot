# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_default_guild_id_here

# Discord Player Configuration
DP_FORCE_YTDL_MOD=@distube/ytdl-core
YOUTUBE_COOKIES_PATH=
DEFAULT_VOLUME=50
IDLE_TIMEOUT_MS=300000

# Web Dashboard Configuration (Add these)
CLIENT_SECRET=your_client_secret_from_discord_developer_portal
CALLBACK_URL=http://localhost:3000/auth/callback
SESSION_SECRET=generate_with_command_below
PORT=3000
# Optional: set to "true" to only allow users in the bot's voice channel to control from dashboard
# DASHBOARD_REQUIRE_VOICE_CHANNEL=false

# Environment
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# HOW TO FILL IN THESE VALUES
# ============================================

# DISCORD_TOKEN:
#   1. Go to https://discord.com/developers/applications
#   2. Select your application
#   3. Go to "Bot" section
#   4. Click "Reset Token" and copy it

# CLIENT_ID:
#   1. Go to https://discord.com/developers/applications
#   2. Select your application
#   3. Copy the "Application ID" from the General Information page

# CLIENT_SECRET (NEW - for Dashboard):
#   1. Go to https://discord.com/developers/applications
#   2. Select your application
#   3. Go to "OAuth2" → "General"
#   4. Click "Reset Secret" and copy it

# SESSION_SECRET (NEW - for Dashboard):
#   Generate a random secure string with this command:
#   
#   Windows PowerShell:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   
#   Linux/Mac:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# CALLBACK_URL:
#   Development: http://localhost:3000/auth/callback
#   Production: https://yourdomain.com/auth/callback
#   
#   IMPORTANT: Add this URL to Discord OAuth2 Redirects:
#   Discord Developer Portal → OAuth2 → Redirects → Add Redirect

# ============================================
# PRODUCTION SETTINGS
# ============================================

# For production deployment, change:
# NODE_ENV=production
# CALLBACK_URL=https://yourdomain.com/auth/callback
# SESSION_SECRET=use_a_different_longer_secret_for_production
# LOG_LEVEL=warn

# ============================================
# OPTIONAL SETTINGS
# ============================================

# YOUTUBE_COOKIES_PATH=./youtube-cookies.txt
# DEFAULT_VOLUME=50 (0-100)
# IDLE_TIMEOUT_MS=300000 (5 minutes in milliseconds)
