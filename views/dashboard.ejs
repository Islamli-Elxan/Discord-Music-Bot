                <ul id="modal-guild-list" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:4px;"></ul>
                <p id="modal-guild-empty" class="hidden" style="text-align:center;padding:32px;color:var(--muted);">No mutual servers found.</p>
            </div>
