                </div>

                <!-- HISTORY VIEW -->
                <div id="view-history" class="view" style="padding:32px;max-width:1200px;margin:0 auto;">
                    <h2 style="font-family:'Clash Display',sans-serif;font-size:28px;font-weight:700;margin-bottom:24px;">Listening History</h2>
                    <div class="card" style="border-radius:16px;overflow:hidden;padding:8px;">
                        <div data-history-container id="history-full">
