<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music Dashboard — <%= user.username %></title>
    <script>
        // React dashboard is served from /dashboard-react/.
        // Keep this EJS route for backward compatibility after auth.
        window.location.replace("/dashboard-react/" + window.location.search);
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
        :root{--bg:#0A0A0F;--surface:#111118;--elevated:#1A1A26;--primary:#8B5CF6;--primary-glow:rgba(139,92,246,0.3);--secondary:#EC4899;--success:#22C55E;--text:#F1F0FF;--muted:#8B8BA7;--border:rgba(255,255,255,0.07);}
        *{font-family:'DM Sans',sans-serif;box-sizing:border-box;}
        h1,h2,h3,h4,.display{font-family:'Clash Display',sans-serif;}
        .mono{font-family:'JetBrains Mono',monospace;}
        body{background:var(--bg);color:var(--text);overflow:hidden;}

        /* Glass */
        .glass{background:rgba(255,255,255,0.02);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--border);}
        .card{background:var(--surface);border:1px solid var(--border);border-radius:16px;transition:all .2s cubic-bezier(.4,0,.2,1);}
        .card:hover{background:var(--elevated);border-color:rgba(139,92,246,.2);}

        /* Gradient text */
        .grad{background:linear-gradient(135deg,var(--primary),var(--secondary));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

        /* Scrollbar */
        ::-webkit-scrollbar{width:5px;height:5px;}
        ::-webkit-scrollbar-track{background:transparent;}
        ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:10px;}
        ::-webkit-scrollbar-thumb:hover{background:rgba(139,92,246,.5);}
        .no-scroll::-webkit-scrollbar{display:none;} .no-scroll{-ms-overflow-style:none;scrollbar-width:none;}

        /* Range inputs */
        input[type=range]{-webkit-appearance:none;background:rgba(255,255,255,.1);border-radius:4px;height:4px;outline:none;cursor:pointer;}
        input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:12px;height:12px;border-radius:50%;background:#fff;cursor:pointer;box-shadow:0 0 8px var(--primary-glow);transition:transform .1s;}
        input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.3);}

        /* Sidebar nav */
        .nav-link{position:relative;display:flex;align-items:center;padding:10px 16px;border-radius:10px;color:var(--muted);font-weight:500;transition:all .2s;cursor:pointer;text-decoration:none;}
        .nav-link::before{content:'';position:absolute;left:-16px;top:50%;transform:translateY(-50%);width:3px;height:0;background:var(--primary);border-radius:0 4px 4px 0;transition:height .2s;box-shadow:0 0 8px var(--primary);}
        .nav-link:hover,.nav-link.active{color:#fff;background:rgba(255,255,255,.04);}
        .nav-link.active::before{height:100%;top:0;transform:none;}
        .nav-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);padding:8px 16px;margin-top:16px;}

        /* Views */
        .view{display:none;opacity:0;transform:translateY(8px);transition:all .3s cubic-bezier(.4,0,.2,1);}
        .view.active{display:block;opacity:1;transform:translateY(0);}

        /* Waveform */
        .wave-bar{width:4px;background:var(--primary);border-radius:4px;display:inline-block;margin:0 1px;transform-origin:bottom;animation:wave 1s ease-in-out infinite both;}
        .wave-bar:nth-child(1){height:14px;animation-delay:0s;}
        .wave-bar:nth-child(2){height:22px;animation-delay:.15s;}
        .wave-bar:nth-child(3){height:30px;animation-delay:.3s;}
        .wave-bar:nth-child(4){height:22px;animation-delay:.15s;}
        .wave-bar:nth-child(5){height:14px;animation-delay:.45s;}
        .wave-bar.paused{animation-play-state:paused;transform:scaleY(.3);}
        @keyframes wave{0%,100%{transform:scaleY(.4)}50%{transform:scaleY(1)}}

        /* Progress bar */
        .prog-wrap{position:relative;height:6px;background:var(--elevated);border-radius:99px;cursor:pointer;}
        .prog-fill{position:absolute;left:0;top:0;height:100%;background:linear-gradient(90deg,var(--primary),var(--secondary));border-radius:99px;pointer-events:none;transition:width .3s;}
        .prog-thumb{position:absolute;right:0;top:50%;width:13px;height:13px;background:#fff;border-radius:50%;transform:translate(50%,-50%) scale(0);opacity:0;transition:all .15s;box-shadow:0 0 8px rgba(0,0,0,.5);}
        .prog-wrap:hover .prog-thumb{opacity:1;transform:translate(50%,-50%) scale(1);}

        /* Toast */
        .toast{position:fixed;bottom:96px;right:24px;padding:12px 20px;background:rgba(20,20,30,.95);border:1px solid rgba(139,92,246,.3);border-left:4px solid var(--primary);border-radius:10px;color:#fff;font-size:14px;z-index:999;transform:translateX(120%);transition:transform .3s cubic-bezier(.4,0,.2,1);backdrop-filter:blur(10px);min-width:220px;}
        .toast.show{transform:translateX(0);}
        .toast.error{border-left-color:#ef4444;border-color:rgba(239,68,68,.3);}

        /* Socket dot */
        .socket-status{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:6px;flex-shrink:0;}
        .socket-status.connected{background:var(--success);box-shadow:0 0 8px var(--success);animation:pulse-dot 2s infinite;}
        .socket-status.disconnected{background:#ef4444;}
        @keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}

        /* List rows */
        .list-row{border-bottom:1px solid rgba(255,255,255,.03);transition:background .15s;}
        .list-row:hover{background:rgba(255,255,255,.04);}
        .list-row .row-action{opacity:0;transition:opacity .15s;}
        .list-row:hover .row-action{opacity:1;}

        /* Control buttons */
        .ctrl{color:var(--muted);transition:all .2s;background:none;border:none;cursor:pointer;}
        .ctrl:hover{color:#fff;transform:scale(1.1);}

        .hidden{display:none!important;}
        .modal-backdrop{background:rgba(0,0,0,.75);backdrop-filter:blur(6px);}
    </style>
</head>
<body style="background:var(--bg);">
    <div style="display:flex;height:100vh;overflow:hidden;">

        <!-- SIDEBAR -->
        <aside style="width:240px;flex-shrink:0;display:flex;flex-direction:column;background:var(--bg);border-right:1px solid var(--border);">
            <!-- Logo -->
            <div style="padding:24px 20px 20px;border-bottom:1px solid var(--border);">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--secondary));display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;box-shadow:0 0 20px var(--primary-glow);">
                        <i class="fas fa-music"></i>
                    </div>
                    <span class="grad" style="font-size:20px;font-weight:700;font-family:'Clash Display',sans-serif;">MusicBot</span>
                </div>
            </div>

            <!-- Nav -->
            <nav style="flex:1;padding:16px;overflow-y:auto;" class="no-scroll">
                <div class="nav-section-label">Menu</div>
                <a href="#" class="nav-link active" data-view="nowplaying" style="margin-bottom:2px;">
                    <i class="fas fa-headphones-alt" style="width:20px;text-align:center;margin-right:12px;"></i>Now Playing
                </a>
                <a href="#" class="nav-link" data-view="queue" style="margin-bottom:2px;">
                    <i class="fas fa-list-ul" style="width:20px;text-align:center;margin-right:12px;"></i>Queue
                </a>
                <a href="#" class="nav-link" data-view="playlists" style="margin-bottom:2px;">
                    <i class="fas fa-layer-group" style="width:20px;text-align:center;margin-right:12px;"></i>Playlists
                </a>
                <a href="#" class="nav-link" data-view="search" style="margin-bottom:2px;">
                    <i class="fas fa-search" style="width:20px;text-align:center;margin-right:12px;"></i>Search
                </a>
                <div class="nav-section-label">Library</div>
                <a href="#" class="nav-link" data-view="history" style="margin-bottom:2px;">
                    <i class="fas fa-history" style="width:20px;text-align:center;margin-right:12px;"></i>History
                </a>
                <a href="#" class="nav-link" data-view="settings" style="margin-bottom:2px;">
                    <i class="fas fa-cog" style="width:20px;text-align:center;margin-right:12px;"></i>Settings
                </a>
            </nav>

            <!-- Server + User -->
            <div style="padding:16px;border-top:1px solid var(--border);">
                <div id="btn-select-server" style="display:flex;align-items:center;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;cursor:pointer;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(139,92,246,.4)'" onmouseout="this.style.borderColor='var(--border)'">
                    <div style="width:36px;height:36px;border-radius:8px;background:var(--elevated);display:flex;align-items:center;justify-content:center;color:var(--muted);"><i class="fas fa-server" style="font-size:14px;"></i></div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Select Server</div>
                        <div style="display:flex;align-items:center;font-size:11px;color:var(--muted);">
                            <span class="socket-status disconnected" id="socket-status-dot"></span>
                            <span id="socket-status">Connecting...</span>
                        </div>
                    </div>
                    <i class="fas fa-chevron-up" style="color:var(--muted);font-size:11px;"></i>
                </div>
                <div style="display:flex;align-items:center;gap:10px;margin-top:12px;padding:8px;">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png"
                         style="width:34px;height:34px;border-radius:50%;border:2px solid var(--border);"
                         onerror="this.onerror=null;this.src='https://cdn.discordapp.com/embed/avatars/0.png';">
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= user.username %></div>
                        <div style="font-size:11px;color:var(--muted);">#<%= user.discriminator %></div>
                    </div>
                    <a href="/logout" style="color:var(--muted);transition:color .2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--muted)'"><i class="fas fa-sign-out-alt"></i></a>
                </div>
            </div>
        </aside>
        

        <!-- MAIN -->
        <main style="flex:1;display:flex;flex-direction:column;background:var(--surface);position:relative;overflow:hidden;">
            <!-- ambient glows -->
            <div style="position:absolute;top:-200px;right:-200px;width:600px;height:600px;background:var(--primary);border-radius:50%;filter:blur(150px);opacity:.08;pointer-events:none;"></div>
            <div style="position:absolute;bottom:-200px;left:-200px;width:500px;height:500px;background:var(--secondary);border-radius:50%;filter:blur(150px);opacity:.08;pointer-events:none;"></div>

            <!-- Header -->
            <header style="height:64px;padding:0 32px;display:flex;align-items:center;justify-between;border-bottom:1px solid var(--border);flex-shrink:0;position:relative;z-index:10;background:rgba(17,17,24,.8);backdrop-filter:blur(12px);">
                <div id="header-title">
                    <h2 style="font-size:22px;font-weight:700;font-family:'Clash Display',sans-serif;color:var(--text);">Now Playing</h2>
                </div>
                <div style="display:flex;align-items:center;gap:16px;">
                    <div style="display:flex;align-items:center;gap:8px;background:var(--bg);border:1px solid var(--border);border-radius:99px;padding:8px 16px;">
                        <i class="fas fa-search" style="color:var(--muted);font-size:13px;"></i>
                        <input id="quick-search" type="text" placeholder="Search... (⌘K)" style="background:none;border:none;outline:none;color:var(--text);font-size:13px;width:180px;" oninput="handleQuickSearch(this.value)">
                        <kbd style="font-size:10px;background:var(--elevated);color:var(--muted);padding:2px 6px;border-radius:4px;font-family:inherit;">⌘K</kbd>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);">
                        <span class="socket-status disconnected" id="socket-status-dot2"></span>
                    </div>
                    <button id="btn-select-server-hdr" style="display:flex;align-items:center;gap:8px;background:var(--elevated);border:1px solid var(--border);border-radius:10px;padding:8px 14px;color:var(--text);font-size:13px;font-weight:600;cursor:pointer;transition:border-color .2s;" onmouseover="this.style.borderColor='rgba(139,92,246,.5)'" onmouseout="this.style.borderColor='var(--border)'">
                        <i class="fas fa-server" style="color:var(--primary);"></i> Select Server
                    </button>
                </div>
            </header>

            <!-- Views container -->
            <div style="flex:1;overflow-y:auto;padding-bottom:96px;" class="no-scroll">

                <!-- NOW PLAYING VIEW -->
                <div id="view-nowplaying" class="view active" style="padding:32px;max-width:1200px;margin:0 auto;">
                    <!-- Hero card -->
                    <div class="glass" style="border-radius:24px;padding:32px;display:flex;gap:40px;align-items:center;margin-bottom:32px;position:relative;overflow:hidden;">
                        <!-- Album art -->
                        <div style="flex-shrink:0;position:relative;">
                            <img id="main-artwork" src="<%= (currentSong && (currentSong.albumArt || currentSong.thumbnail)) || '' %>"
                                 style="width:280px;height:280px;border-radius:18px;object-fit:cover;background:var(--elevated);box-shadow:0 20px 60px rgba(139,92,246,.25);"
                                 onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||'';">
                        </div>
                        <!-- Info + controls -->
                        <div style="flex:1;min-width:0;">
                            <!-- waveform + label -->
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                                <div id="waveform" style="display:flex;align-items:flex-end;gap:2px;height:30px;">
                                    <div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div><div class="wave-bar"></div>
                                </div>
                                <span style="font-size:11px;font-weight:700;color:var(--primary);text-transform:uppercase;letter-spacing:.08em;background:rgba(139,92,246,.1);padding:3px 10px;border-radius:99px;border:1px solid rgba(139,92,246,.2);">NOW PLAYING</span>
                            </div>
                            <h3 id="main-title" style="font-family:'Clash Display',sans-serif;font-size:36px;font-weight:700;color:var(--text);margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= (currentSong && currentSong.title) || 'Nothing Playing' %></h3>
                            <p id="main-artist" style="font-size:18px;color:var(--muted);margin-bottom:28px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= (currentSong && currentSong.artist) || 'Queue tracks to get started' %></p>
                            <!-- Progress -->
                            <div style="margin-bottom:28px;">
                                <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                                    <span id="main-current-time" class="mono" style="font-size:12px;color:var(--muted);">0:00</span>
                                    <span id="main-total-time" class="mono" style="font-size:12px;color:var(--muted);">0:00</span>
                                </div>
                                <div class="prog-wrap" id="main-progress-wrap">
                                    <div class="prog-fill" id="main-progress-fill" style="width:<%= (currentSong && currentSong.duration) ? ((currentSong.currentTime||0)/currentSong.duration*100) : 0 %>%;"><div class="prog-thumb"></div></div>
                                </div>
                            </div>
                            <!-- Controls -->
                            <div style="display:flex;align-items:center;justify-content:space-between;">
                                <div style="display:flex;align-items:center;gap:24px;">
                                    <button class="ctrl btn-shuffle" title="Shuffle" style="font-size:18px;"><i class="fas fa-random" id="main-shuffle"></i></button>
                                    <button class="ctrl btn-previous" title="Previous" style="font-size:22px;"><i class="fas fa-step-backward"></i></button>
                                    <button class="btn-play-pause" title="Play/Pause" style="width:62px;height:62px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--secondary));border:none;color:#fff;font-size:22px;cursor:pointer;box-shadow:0 0 30px var(--primary-glow);transition:transform .15s,box-shadow .15s;" onmouseover="this.style.transform='scale(1.07)'" onmouseout="this.style.transform='scale(1)'">
                                        <i class="fas fa-<%= isPlaying ? 'pause' : 'play' %>" id="main-play-icon"></i>
                                    </button>
                                    <button class="ctrl btn-skip" title="Next" style="font-size:22px;"><i class="fas fa-step-forward"></i></button>
                                    <button class="ctrl btn-loop" title="Repeat" style="font-size:18px;"><i class="fas fa-redo" id="main-loop"></i></button>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;width:140px;">
                                    <i class="fas fa-volume-up" style="color:var(--muted);font-size:14px;"></i>
                                    <input type="range" id="main-volume" min="0" max="100" value="50" style="flex:1;">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Up Next + Recently Played split -->
                    <div style="display:grid;grid-template-columns:1fr 340px;gap:24px;">
                        <!-- Up Next -->
                        <div>
                            <div style="display:flex;align-items:center;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid var(--border);margin-bottom:12px;">
                                <h4 style="font-family:'Clash Display',sans-serif;font-size:18px;font-weight:700;">Up Next</h4>
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span id="queue-count" style="font-size:12px;color:var(--muted);background:var(--elevated);padding:3px 10px;border-radius:99px;">0 tracks</span>
                                    <button id="btn-clear-queue" style="font-size:12px;color:#ef4444;background:none;border:none;cursor:pointer;transition:opacity .2s;" onmouseover="this.style.opacity='.7'" onmouseout="this.style.opacity='1'"><i class="fas fa-trash-alt"></i> Clear</button>
                                </div>
                            </div>
                            <div data-queue-container id="queue-list" style="min-height:120px;"></div>
                        </div>
                        <!-- Recently Played -->
                        <div>
                            <div style="display:flex;align-items:center;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid var(--border);margin-bottom:12px;">
                                <h4 style="font-family:'Clash Display',sans-serif;font-size:18px;font-weight:700;">Recently Played</h4>
                            </div>
                            <div data-history-container style="min-height:120px;">
                                <% if (recentlyPlayed && recentlyPlayed.length) { recentlyPlayed.slice(0,6).forEach(function(song){ var s=song||{}; var ago=''; %>
                                <div class="list-row" style="display:flex;align-items:center;gap:12px;padding:10px 8px;border-radius:10px;">
                                    <img src="<%= s.albumArt||s.thumbnail||'' %>" style="width:44px;height:44px;border-radius:8px;object-fit:cover;background:var(--elevated);" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||'';">
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= s.title||'—' %></div>
                                        <div style="font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= s.artist||'—' %></div>
                                    </div>
                                    <div style="font-size:11px;color:var(--muted);white-space:nowrap;"><%= s.playedAt||'' %></div>
                                </div>
                                <% }); } %>
                                <% if (!recentlyPlayed || !recentlyPlayed.length) { %>
                                <div style="text-align:center;padding:40px;color:var(--muted);"><i class="fas fa-clock" style="font-size:28px;opacity:.3;display:block;margin-bottom:8px;"></i>No history yet</div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- QUEUE VIEW -->
                <div id="view-queue" class="view" style="padding:32px;max-width:1200px;margin:0 auto;">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
                        <div><h2 style="font-family:'Clash Display',sans-serif;font-size:28px;font-weight:700;">Queue</h2><p style="color:var(--muted);font-size:14px;margin-top:4px;">Track order management</p></div>
                        <button id="btn-clear-queue2" style="display:flex;align-items:center;gap:8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:9px 16px;color:#ef4444;font-size:13px;font-weight:600;cursor:pointer;"><i class="fas fa-trash-alt"></i> Clear Queue</button>
                    </div>
                    <div class="card" style="border-radius:16px;overflow:hidden;min-height:400px;">
                        <div style="display:grid;grid-template-columns:40px 1fr auto auto;gap:12px;padding:12px 20px;border-bottom:1px solid var(--border);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">
                            <span>#</span><span>Title / Artist</span><span style="text-align:right;">Time</span><span></span>
                        </div>
                        <div data-queue-container id="queue-list-full" style="padding:8px;"></div>
                    </div>
                </div>

                <!-- PLAYLISTS VIEW -->
                <div id="view-playlists" class="view" style="padding:32px;max-width:1200px;margin:0 auto;">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;">
                        <h2 style="font-family:'Clash Display',sans-serif;font-size:28px;font-weight:700;">Playlists</h2>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px;">
                        <div class="card" style="padding:16px;cursor:pointer;border-radius:16px;" data-playlist="electro">
                            <div style="aspect-ratio:1;background:var(--elevated);border-radius:10px;overflow:hidden;margin-bottom:14px;position:relative;">
                                <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=400&q=80" style="width:100%;height:100%;object-fit:cover;">
                                <div style="position:absolute;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;" class="playlist-overlay">
                                    <div style="width:44px;height:44px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 0 20px var(--primary-glow);"><i class="fas fa-play"></i></div>
                                </div>
                            </div>
                            <div style="font-weight:700;font-size:15px;margin-bottom:4px;">Electro Mix</div>
                            <div style="font-size:12px;color:var(--muted);">Electronic & Dance</div>
                        </div>
                        <div class="card" style="padding:16px;cursor:pointer;border-radius:16px;" data-playlist="rock">
                            <div style="aspect-ratio:1;background:var(--elevated);border-radius:10px;overflow:hidden;margin-bottom:14px;position:relative;">
                                <img src="https://images.unsplash.com/photo-1498038432885-c6f3f1b912ee?w=400&q=80" style="width:100%;height:100%;object-fit:cover;">
                                <div style="position:absolute;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;" class="playlist-overlay">
                                    <div style="width:44px;height:44px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 0 20px var(--primary-glow);"><i class="fas fa-play"></i></div>
                                </div>
                            </div>
                            <div style="font-weight:700;font-size:15px;margin-bottom:4px;">Rock Classics</div>
                            <div style="font-size:12px;color:var(--muted);">Best of Rock</div>
                        </div>
                    </div>
                </div>

                <!-- SEARCH VIEW -->
                <div id="view-search" class="view" style="padding:40px 32px;max-width:900px;margin:0 auto;">
                    <h2 style="font-family:'Clash Display',sans-serif;font-size:32px;font-weight:700;text-align:center;margin-bottom:28px;">What do you want to listen to?</h2>
                    <div style="position:relative;margin-bottom:32px;">
                        <i class="fas fa-search" style="position:absolute;left:20px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:18px;"></i>
                        <input type="text" id="search-input" placeholder="Search tracks, artists, playlists..." style="width:100%;background:var(--elevated);border:1px solid var(--border);border-radius:99px;padding:16px 120px 16px 52px;font-size:15px;color:var(--text);outline:none;transition:border-color .2s;" onfocus="this.style.borderColor='rgba(139,92,246,.5)'" onblur="this.style.borderColor='var(--border)'">
                        <button id="search-btn" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:var(--primary);border:none;border-radius:99px;padding:10px 20px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;transition:background .2s;" onmouseover="this.style.background='var(--secondary)'" onmouseout="this.style.background='var(--primary)'">Search</button>
                    </div>
