                <button class="ctrl bar-shuffle" title="Shuffle" style="font-size:14px;"><i class="fas fa-random" id="bar-shuffle"></i></button>
                <button class="ctrl bar-previous" title="Previous" style="font-size:18px;"><i class="fas fa-step-backward"></i></button>
                <button class="bar-play-pause" style="width:40px;height:40px;border-radius:50%;background:#fff;border:none;color:#0A0A0F;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .15s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                    <i class="fas fa-<%= isPlaying ? 'pause' : 'play' %>" id="bar-play-icon"></i>
                </button>
                <button class="ctrl bar-skip" title="Next" style="font-size:18px;"><i class="fas fa-step-forward"></i></button>
                <button class="ctrl bar-loop" title="Loop" style="font-size:14px;"><i class="fas fa-redo" id="bar-loop"></i></button>
            </div>
            <div style="display:flex;align-items:center;gap:10px;width:100%;max-width:520px;">
                <span id="bar-current-time" class="mono" style="font-size:11px;color:var(--muted);width:34px;text-align:right;"><%= (currentSong && typeof currentSong.currentTime==='number') ? (Math.floor(currentSong.currentTime/60)+':'+(currentSong.currentTime%60).toString().padStart(2,'0')) : '0:00' %></span>
                <div style="flex:1;position:relative;">
                    <input type="range" id="bar-progress" min="0" max="<%= (currentSong && currentSong.duration) ? currentSong.duration : 1 %>" value="<%= (currentSong && typeof currentSong.currentTime==='number') ? currentSong.currentTime : 0 %>" style="width:100%;">
