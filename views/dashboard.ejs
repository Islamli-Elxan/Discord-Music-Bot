        </div>
    </div>

    <!-- TOAST -->
    <div id="toast" class="toast" role="status" aria-live="polite"></div>

    <script>
        window.DASHBOARD_GUILD_ID = '<%= typeof selectedGuild !== "undefined" ? selectedGuild : "" %>';
        window.DASHBOARD_DEFAULT_ART = 'https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=400&auto=format&fit=crop';
    </script>
    <script>
        (function() {
            'use strict';
            var STORAGE_KEY = 'dashboard_lastGuildId';
            
            console.log('═══════════════════════════════════════');
            console.log('🔌 Initializing Socket.io connection...');
            console.log('   Target: http://localhost:3000');
            console.log('   Transport: websocket');
            console.log('═══════════════════════════════════════');
            
            var socket = typeof io !== 'undefined' ? io('http://localhost:3000', {
                transports: ['websocket'],
                withCredentials: true,
                reconnection: true,
                reconnectionDelay: 2000,
                reconnectionDelayMax: 5000,
                reconnectionAttempts: 30,
                timeout: 10000
            }) : null;
            
            if (!socket) {
                console.error('❌ Socket.io library not loaded!');
                var statusEl = document.getElementById('socket-status');
                if (statusEl) statusEl.innerText = 'Socket.io failed to load';
                return;
            }
            console.log('✅ Socket.io client initialized');

            var params = new URLSearchParams(window.location.search);
            var guildId = params.get('guild_id') || params.get('guild') || (typeof window.DASHBOARD_GUILD_ID !== 'undefined' ? window.DASHBOARD_GUILD_ID : '') || (typeof localStorage !== 'undefined' ? localStorage.getItem(STORAGE_KEY) : null) || '';
            guildId = (guildId && String(guildId).trim()) || '';
            if (guildId && typeof localStorage !== 'undefined') try { localStorage.setItem(STORAGE_KEY, guildId); } catch (e) {}

            function setSocketStatus(connected, text) {
                var dots = document.querySelectorAll('.socket-status');
                dots.forEach(function(dot) {
                    dot.className = 'socket-status ' + (connected ? 'connected' : 'disconnected');
                });
                var txt = document.getElementById('socket-status');
                if (txt) txt.innerText = text != null ? text : (connected ? 'Connected' : 'Disconnected');
            }

            function joinGuildAndRequestState() {
                if (!guildId) return;
                socket.emit('join-guild', guildId);
                if (typeof console !== 'undefined' && console.log) console.log('Joining guild:', guildId);
            }

            socket.on('connect', function() {
                console.log('═══════════════════════════════════════');
                console.log('✅ Socket CONNECTED!');
                console.log('   Socket ID:', socket.id);
                console.log('   Guild ID:', guildId || 'NONE');
                console.log('═══════════════════════════════════════');
                setSocketStatus(true, 'Connected');
                
                if (guildId) {
                    joinGuildAndRequestState();
                } else {
                    console.warn('⚠️ No guild ID — forcing Select Server modal');
                    setTimeout(function() {
                        var modal = document.getElementById('modal-select-server');
                        var btn = document.getElementById('btn-select-server');
                        if (modal) {
                            modal.classList.remove('hidden');
                            console.log('✅ Opened Select Server modal');
                        } else if (btn) {
                            btn.click();
                            console.log('✅ Clicked Select Server button');
                        }
                    }, 100);
                }
            });

            socket.on('disconnect', function(reason) {
                console.warn('🔴 Socket disconnected. Reason:', reason);
                setSocketStatus(false, 'Disconnected');
                showToast('Disconnected. Reconnecting...', false);
            });

            socket.on('connect_error', function(err) {
                console.error('═══════════════════════════════════════');
                console.error('❌ Socket Connection Error');
                console.dir(err);
                console.error('Error message:', err.message);
                console.error('Error type:', err.type || 'unknown');
                console.error('Error data:', err.data || 'none');
                console.error('Error description:', err.description || 'none');
                console.error('Stack:', err.stack || 'no stack');
                console.error('═══════════════════════════════════════');
                setSocketStatus(false, 'Error: ' + err.message);
                var statusEl = document.getElementById('socket-status');
                if (statusEl) statusEl.innerText = 'Error: ' + err.message;
                showToast('Connection error: ' + err.message, true);
            });

            socket.on('reconnect_attempt', function(attemptNumber) {
                console.log('🔄 Reconnection attempt', attemptNumber);
            });

            socket.on('reconnect', function(attemptNumber) {
                console.log('✅ Reconnected after', attemptNumber, 'attempts');
                setSocketStatus(true, 'Reconnected');
            });

            socket.on('reconnect_failed', function() {
                console.error('❌ Reconnection failed');
                setSocketStatus(false, 'Connection failed');
                showToast('Unable to connect to server', true);
            });

            function fmtTime(sec) {
                sec = Math.floor(Number(sec) || 0);
                var m = Math.floor(sec / 60);
                var s = sec % 60;
                return m + ':' + (s < 10 ? '0' : '') + s;
            }

            function showToast(msg, isError) {
                var el = document.getElementById('toast');
                if (!el) return;
                el.textContent = msg || '';
                el.classList.toggle('error', !!isError);
                el.classList.add('show');
                clearTimeout(window._toastTimer);
                window._toastTimer = setTimeout(function() { el.classList.remove('show'); }, 3000);
            }
            function handleResponse(res) {
                if (res && res.error) showToast(res.error, true);
            }

            // Dashboard: show predicted next track (smart autoplay)
            socket.on('autoplay:next-predicted', function(data) {
                try {
                    if (!data || !data.prediction) return;
                    var p = data.prediction;
                    var title = p.title || 'Unknown';
                    var artist = p.artist || '';
                    showToast('Next suggested: ' + title + (artist ? ' - ' + artist : ''), false);
                } catch (e) {}
            });

            // Live progress state for ticker
            var progressState = { currentTime: 0, duration: 0, isPlaying: false, trackStartMs: 0 };
            var progressIntervalId = null;
            function stopProgressTicker() {
                if (progressIntervalId) { clearInterval(progressIntervalId); progressIntervalId = null; }
            }
            function updateProgressUI(cur, dur) {
                var c = Number(cur);
                var d = Number(dur);
                if (isNaN(c)) c = 0;
                if (isNaN(d) || d <= 0) d = 1;
                var leftLbl = fmtTime(c);
                var rightLbl = fmtTime(d);
                var el;
                if ((el = document.getElementById('main-current-time'))) el.innerText = leftLbl;
                if ((el = document.getElementById('bar-current-time'))) el.innerText = leftLbl;
                if ((el = document.getElementById('main-total-time'))) el.innerText = rightLbl;
                if ((el = document.getElementById('bar-total-time'))) el.innerText = rightLbl;
                var bar = document.getElementById('bar-progress');
                if (bar) { bar.max = d; bar.value = Math.max(0, Math.min(c, d)); }
                if ((el = document.getElementById('main-progress-fill'))) el.style.width = (d ? (c / d * 100) : 0) + '%';
            }
            function tickProgress() {
                if (!progressState.isPlaying || !progressState.duration) return;
                var elapsed = (Date.now() - progressState.trackStartMs) / 1000;
                var cur = Math.min(progressState.currentTime + elapsed, progressState.duration);
                progressState.currentTime = cur;
                updateProgressUI(cur, progressState.duration);
            }
            function resetProgressBar() {
                stopProgressTicker();
                progressState.currentTime = 0;
                progressState.duration = 0;
                progressState.isPlaying = false;
                progressState.trackStartMs = 0;
                updateProgressUI(0, 0);
            }

            // 7. player:update — update UI (wrapped in try/catch so one error doesn't kill the script)
            socket.on('player:update', function(data) {
                try {
                    if (!data) return;
                    var track = data.currentTrack || null;
                    var isPlaying = !!data.isPlaying;
                    var vol = typeof data.volume === 'number' ? data.volume : 50;
                    var dur = (track && (typeof track.duration === 'number')) ? track.duration : 0;
                    var cur = (track && (typeof track.currentTime === 'number')) ? track.currentTime : 0;
                    var defArt = window.DASHBOARD_DEFAULT_ART || '';

                    if (track) {
                        progressState.currentTime = cur;
                        progressState.duration = Math.max(0, dur);
                        progressState.isPlaying = isPlaying;
                        progressState.trackStartMs = Date.now();
                        stopProgressTicker();
                        if (isPlaying && dur > 0) progressIntervalId = setInterval(tickProgress, 1000);

                        var el;
                        var art = track.albumArt || track.thumbnail || defArt;
                        var title = track.title || '—';
                        var artist = track.artist || track.author || '—';
                        if ((el = document.getElementById('main-artwork'))) { el.src = art || el.src; }
                        if ((el = document.getElementById('bar-artwork'))) { el.src = art || el.src; }
                        if ((el = document.getElementById('main-title'))) el.innerText = title;
                        if ((el = document.getElementById('bar-title'))) el.innerText = title;
                        if ((el = document.getElementById('main-artist'))) el.innerText = artist;
                        if ((el = document.getElementById('bar-artist'))) el.innerText = artist;
                        updateProgressUI(cur, dur);
                        var progressBar = document.getElementById('bar-progress');
                        if (progressBar) {
                            progressBar.max = dur > 0 ? dur : 1;
                            progressBar.value = Math.max(0, Math.min(cur, dur || 1));
                        }
                    } else {
                        resetProgressBar();
                    }

                    progressState.isPlaying = isPlaying;
                    if (!isPlaying) stopProgressTicker();
                    var mainIcon = document.getElementById('main-play-icon');
                    var barIcon = document.getElementById('bar-play-icon');
                    var icon = isPlaying ? 'pause' : 'play';
                    if (mainIcon) mainIcon.className = 'fas fa-' + icon;
                    if (barIcon) barIcon.className = 'fas fa-' + icon;

                    if (typeof data.isShuffled !== 'undefined') {
                        var shuffleClass = data.isShuffled ? 'accent-purple' : 'text-gray-300';
                        document.querySelectorAll('#main-shuffle, #bar-shuffle').forEach(function(el) {
                            if (el) el.className = 'fas fa-random ' + shuffleClass;
                        });
                    }
                    if (typeof data.loopMode !== 'undefined') {
                        var loopActive = data.loopMode === 1 || data.loopMode === 2 || data.loopMode === 3;
                        var loopClass = loopActive ? 'accent-purple' : 'text-gray-300';
                        document.querySelectorAll('#main-loop, #bar-loop').forEach(function(el) {
                            if (el) el.className = 'fas fa-redo ' + loopClass;
                        });
                    }
                    if ((el = document.getElementById('bar-volume-value'))) el.innerText = vol + '%';
                    if ((el = document.getElementById('bar-volume'))) el.value = vol;

                    if (Array.isArray(data.queue)) {
                        var upNext = document.querySelector('[data-queue-container]');
                        var countEl = document.getElementById('queue-count');
                        if (countEl) countEl.innerText = data.queue.length + ' tracks';
                        if (upNext) {
                            if (data.queue.length === 0) {
                                upNext.innerHTML = '<div class="text-center py-12 text-gray-500"><i class="fas fa-music text-4xl mb-4 opacity-30"></i><p>No songs in queue</p></div>';
                            } else {
                                upNext.innerHTML = data.queue.map(function(t, i) {
                                    var artUrl = (t && (t.albumArt || t.thumbnail)) || defArt;
                                    return '<div class="queue-item flex items-center gap-4 p-3 rounded-lg transition">' +
                                        '<span class="text-gray-500 font-medium w-6">' + (i + 1) + '</span>' +
                                        '<img src="' + artUrl + '" class="w-12 h-12 rounded object-cover" alt="" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||\'\';">' +
                                        '<div class="flex-1 min-w-0"><p class="font-medium truncate">' + ((t && t.title) || '—') + '</p><p class="text-sm text-gray-400 truncate">' + ((t && t.artist) || '—') + '</p></div>' +
                                        '<div class="text-right"><p class="text-sm text-gray-400">' + fmtTime((t && t.duration) || 0) + '</p><p class="text-xs text-gray-500">' + ((t && t.requestedBy) || '') + '</p></div>' +
                                        '<button type="button" class="queue-remove-btn text-gray-400 hover:text-red-500 transition" data-queue-index="' + i + '" title="Remove"><i class="fas fa-times"></i></button>' +
                                        '</div>';
                                }).join('');
                            }
                        }
                    }
                    if (Array.isArray(data.history)) {
                        var histHtml = data.history.slice(0, 10).map(function(h) {
                            var ago = 'recently';
                            if (h && h.playedAt) {
                                var d = new Date(h.playedAt);
                                var secs = Math.floor((new Date() - d) / 1000);
                                if (secs < 60) ago = 'just now';
                                else if (secs < 3600) ago = Math.floor(secs / 60) + ' min ago';
                                else ago = Math.floor(secs / 3600) + ' hr ago';
                            }
                            var artUrl = (h && (h.albumArt || h.thumbnail)) || defArt;
                            return '<div class="queue-item flex items-center gap-4 p-3 rounded-lg transition">' +
                                '<img src="' + artUrl + '" class="w-14 h-14 rounded object-cover" alt="" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||\'\';">' +
                                '<div class="flex-1 min-w-0"><p class="font-medium truncate">' + ((h && h.title) || '—') + '</p><p class="text-sm text-gray-400 truncate">' + ((h && h.artist) || '—') + '</p></div>' +
                                '<div class="text-right"><p class="text-xs text-gray-500">' + ago + '</p></div></div>';
                        }).join('');
                        document.querySelectorAll('[data-history-container]').forEach(function(container) {
                            if (container) container.innerHTML = histHtml || '<div class="text-center py-8 text-gray-500">No recently played tracks</div>';
                        });
                    }
                } catch (err) {
                    console.error('player:update handler error', err);
                }
            });

            // 4 & 5. Select elements and add event listeners (after DOM ready)
            document.addEventListener('DOMContentLoaded', function() {
                var defArt = window.DASHBOARD_DEFAULT_ART;
                if (defArt) {
                    ['main-artwork', 'bar-artwork'].forEach(function(id) {
                        var el = document.getElementById(id);
                        if (el && (!el.src || el.src === '' || el.getAttribute('src') === '')) el.src = defArt;
                    });
                }
                // --- NEW: View switching ---
                function switchView(viewName) {
                    document.querySelectorAll('.view').forEach(function(v) { v.classList.remove('active'); });
                    document.querySelectorAll('.nav-link').forEach(function(l) { l.classList.remove('active'); });
                    var target = document.getElementById('view-' + viewName);
                    if (target) target.classList.add('active');
                    document.querySelectorAll('.nav-link[data-view="' + viewName + '"]').forEach(function(l) { l.classList.add('active'); });
                    var headerTitle = document.getElementById('header-title');
                    var titles = {nowplaying:'Now Playing',queue:'Queue',playlists:'Playlists',search:'Search',history:'History',settings:'Settings'};
                    if (headerTitle) headerTitle.querySelector('h2').innerText = titles[viewName] || '';
                }
                document.querySelectorAll('.nav-link[data-view]').forEach(function(link) {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        switchView(this.getAttribute('data-view'));
                    });
                });

                // Modal open from sidebar + header buttons
                function openServerModal() {
                    var modal = document.getElementById('modal-select-server');
                    if (modal) { modal.classList.remove('hidden'); modal.style.display = 'flex'; }
                }
                var sidebarBtn = document.getElementById('btn-select-server');
                var hdrBtn = document.getElementById('btn-select-server-hdr');
                if (sidebarBtn) sidebarBtn.addEventListener('click', openServerModal);
                if (hdrBtn) hdrBtn.addEventListener('click', openServerModal);
                var modalClose = document.getElementById('modal-close');
                if (modalClose) modalClose.addEventListener('click', function() {
                    var modal = document.getElementById('modal-select-server');
                    if (modal) { modal.classList.add('hidden'); modal.style.display = 'none'; }
                });

                // Quick search (header) switches to search view
                window.handleQuickSearch = function(val) {
                    if (val.length > 0) {
                        switchView('search');
                        var si = document.getElementById('search-input');
                        if (si) si.value = val;
                    }
                };

                // Playlist card overlays
                document.querySelectorAll('[data-playlist]').forEach(function(card) {
                    var overlay = card.querySelector('.playlist-overlay');
                    if (!overlay) return;
                    card.addEventListener('mouseenter', function() { overlay.style.opacity = '1'; });
                    card.addEventListener('mouseleave', function() { overlay.style.opacity = '0'; });
                });

                // Clear queue buttons
                ['btn-clear-queue','btn-clear-queue2'].forEach(function(id) {
                    var btn = document.getElementById(id);
                    if (btn) btn.addEventListener('click', function() { emitWithGuild('player:clear', {}); });
                });

                // Main progress bar — click to seek
                var mainWrap = document.getElementById('main-progress-wrap');
                if (mainWrap) {
                    mainWrap.addEventListener('click', function(e) {
                        var rect = mainWrap.getBoundingClientRect();
                        var pct = (e.clientX - rect.left) / rect.width;
                        var dur = progressState.duration || 0;
                        if (dur > 0) emitWithGuild('player:seek', { position: Math.floor(pct * dur) });
                    });
                }

                var playPauseButtons = document.querySelectorAll('.btn-play-pause, .bar-play-pause');

                var skipButtons = document.querySelectorAll('.btn-skip, .bar-skip');
                var previousButtons = document.querySelectorAll('.btn-previous, .bar-previous');
                var shuffleButtons = document.querySelectorAll('.btn-shuffle, .bar-shuffle');
                var loopButtons = document.querySelectorAll('.btn-loop, .bar-loop');
                var volumeSlider = document.getElementById('bar-volume');

                function emitWithGuild(evt, payload, cb) {
                    if (!guildId) { if (cb) cb({ error: 'No guild selected' }); return; }
                    socket.emit(evt, typeof payload === 'object' ? Object.assign({}, payload, { guildId: guildId }) : { guildId: guildId }, cb || handleResponse);
                }

                // Smart autoplay settings controls (dashboard Settings view)
                var explorationSlider = document.getElementById('autoplay-exploration');
                var explorationVal = document.getElementById('autoplay-exploration-val');
                if (explorationSlider && explorationVal) {
                    explorationSlider.addEventListener('input', function() {
                        var v = parseInt(this.value, 10);
                        if (isNaN(v)) v = 0;
                        explorationVal.innerText = v + '%';
                    });
                }

                var applyAutoplayBtn = document.getElementById('btn-apply-autoplay-settings');
                if (applyAutoplayBtn) {
                    applyAutoplayBtn.addEventListener('click', function() {
                        var enabledEl = document.getElementById('toggle-autoplay');
                        var modeEl = document.getElementById('autoplay-mode');
                        var blockEl = document.getElementById('autoplay-block-explicit');
                        var sourcesEl = document.getElementById('autoplay-sources');
                        var expEl = document.getElementById('autoplay-exploration');

                        var enabled = !!enabledEl?.checked;
                        var mode = modeEl ? modeEl.value : 'smart';
                        var exploration = expEl ? parseInt(expEl.value, 10) : 20;
                        if (isNaN(exploration)) exploration = 20;
                        var block_explicit = !!blockEl?.checked;
                        var preferred_sources = sourcesEl ? sourcesEl.value : 'both';

                        emitWithGuild('settings:autoplay', {
                            enabled: enabled,
                            mode: mode,
                            exploration_rate: exploration,
                            block_explicit: block_explicit,
                            preferred_sources: preferred_sources
                        }, function(res) {
                            if (res && res.error) showToast(res.error, true);
                            else showToast('Autoplay settings updated');
                        });
                    });
                }

                playPauseButtons.forEach(function(btn) {
                    btn.addEventListener('click', function() { emitWithGuild('player:pause', {}); });
                });
                skipButtons.forEach(function(btn) {
                    btn.addEventListener('click', function() { emitWithGuild('player:skip', {}); });
                });
                previousButtons.forEach(function(btn) {
                    btn.addEventListener('click', function() { emitWithGuild('player:previous', {}); });
                });

                shuffleButtons.forEach(function(btn) {
                    btn.addEventListener('click', function() { emitWithGuild('player:shuffle', {}); });
                });
                loopButtons.forEach(function(btn) {
                    btn.addEventListener('click', function() { emitWithGuild('player:loop', {}); });
                });
                if (volumeSlider) {
                    volumeSlider.addEventListener('input', function(e) {
                        var v = parseInt(e.target.value, 10);
                        if (isNaN(v)) return;
                        var disp = document.getElementById('bar-volume-value');
                        if (disp) disp.innerText = v + '%';
                        emitWithGuild('player:volume', { volume: v });
                    });
                }

                var progressBar = document.getElementById('bar-progress');
                if (progressBar) {
                    progressBar.addEventListener('input', function() {
                        var cur = parseInt(this.value, 10);
                        var dur = parseInt(this.max, 10) || 1;
                        progressState.currentTime = isNaN(cur) ? 0 : cur;
                        progressState.trackStartMs = Date.now();
                        updateProgressUI(progressState.currentTime, dur);
                    });
                    progressBar.addEventListener('change', function() {
                        var seconds = parseInt(this.value, 10);
                        if (isNaN(seconds) || seconds < 0) return;
                        progressState.currentTime = seconds;
                        progressState.trackStartMs = Date.now();
                        emitWithGuild('player:seek', { positionSeconds: seconds }, function(res) {
                            if (res && res.error) showToast(res.error, true);
                        });
                    });
                }
                var mainProgressWrap = document.getElementById('main-progress-wrap');
                if (mainProgressWrap) {
                    mainProgressWrap.addEventListener('click', function(e) {
                        var dur = progressState.duration;
                        if (!dur || dur <= 0) return;
                        var rect = this.getBoundingClientRect();
                        var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
                        var seconds = Math.floor(pct * dur);
                        progressState.currentTime = seconds;
                        progressState.trackStartMs = Date.now();
                        updateProgressUI(seconds, dur);
                        if (progressBar) progressBar.value = seconds;
                        emitWithGuild('player:seek', { positionSeconds: seconds }, function(res) {
                            if (res && res.error) showToast(res.error, true);
                        });
                    });
                }

                var btnClearQueue = document.getElementById('btn-clear-queue');
                if (btnClearQueue) {
                    btnClearQueue.addEventListener('click', function() {
                        emitWithGuild('player:clearQueue', {}, function(res) {
                            if (res && res.error) showToast(res.error, true);
                            else showToast('Queue cleared');
                        });
                    });
                }

                // Event delegation for dynamically rendered queue remove buttons
                var queueList = document.getElementById('queue-list') || document.querySelector('[data-queue-container]');
                if (queueList) {
                    queueList.addEventListener('click', function(e) {
                        var btn = e.target && (e.target.closest ? e.target.closest('.queue-remove-btn') : null);
                        if (!btn) return;
                        e.stopPropagation();
                        var idx = parseInt(btn.getAttribute('data-queue-index'), 10);
                        if (!isNaN(idx) && idx >= 0) emitWithGuild('player:removeTrack', { index: idx });
                    });
                }

                var modal = document.getElementById('modal-select-server');
                var listEl = document.getElementById('modal-guild-list');
                var emptyEl = document.getElementById('modal-guild-empty');
                var btnSelectServer = document.getElementById('btn-select-server');
                if (btnSelectServer) {
                    btnSelectServer.addEventListener('click', function() {
                        socket.emit('get-guilds');
                        if (modal) modal.classList.remove('hidden');
                    });
                }
                socket.on('receive-guilds', function(guilds) {
                    if (!listEl) return;
                    listEl.innerHTML = '';
                    if (!guilds || guilds.length === 0) {
                        if (emptyEl) { emptyEl.classList.remove('hidden'); }
                    } else {
                        if (emptyEl) emptyEl.classList.add('hidden');
                        guilds.forEach(function(g) {
                            var li = document.createElement('li');
                            li.className = 'p-3 rounded-lg hover:bg-gray-800 cursor-pointer flex items-center gap-3';
                            li.innerHTML = '<span class="font-medium">' + (g.name || 'Server') + '</span>';
                            li.dataset.guildId = g.id;
                            li.addEventListener('click', function() {
                                window.location.href = '/dashboard?guild_id=' + encodeURIComponent(g.id);
                            });
                            listEl.appendChild(li);
                        });
                    }
                });
                var modalClose = document.getElementById('modal-close');
                if (modalClose) modalClose.addEventListener('click', function() {
                    if (modal) modal.classList.add('hidden');
                });
                if (modal) {
                    modal.addEventListener('click', function(e) {
                        if (e.target === modal) modal.classList.add('hidden');
                    });
                }

                document.querySelectorAll('.sidebar-item[data-view]').forEach(function(item) {
                    item.addEventListener('click', function(e) {
                        e.preventDefault();
                        var view = item.getAttribute('data-view');
                        document.querySelectorAll('.sidebar-item').forEach(function(s) { s.classList.remove('active'); });
                        item.classList.add('active');
                        document.querySelectorAll('[id^="view-"]').forEach(function(v) {
                            if (v.id === 'view-' + view) v.classList.remove('hidden');
                            else v.classList.add('hidden');
                        });
                    });
                });

                var modalPlaylist = document.getElementById('modal-playlist');
                var modalPlaylistTitle = document.getElementById('modal-playlist-title');
                var modalPlaylistTracks = document.getElementById('modal-playlist-tracks');
                var modalPlaylistPlayAll = document.getElementById('modal-playlist-play-all');
                var modalPlaylistClose = document.getElementById('modal-playlist-close');
                var currentModalPlaylistName = '';

                document.querySelectorAll('.playlist-card').forEach(function(card) {
                    card.addEventListener('click', function() {
                        var playlist = card.getAttribute('data-playlist');
                        if (!socket || !playlist) return;
                        if (!guildId) { showToast('Select a server first.', true); return; }
                        currentModalPlaylistName = playlist;
                        var titleMap = { electro: 'Electro Mix', rock: 'Rock Mix' };
                        if (modalPlaylistTitle) modalPlaylistTitle.textContent = titleMap[playlist] || playlist;
                        if (modalPlaylistTracks) modalPlaylistTracks.innerHTML = '<div class="text-center py-8 text-gray-400"><i class="fas fa-spinner fa-spin mr-2"></i>Loading tracks...</div>';
                        if (modalPlaylist) modalPlaylist.classList.remove('hidden');
                        socket.emit('get-playlist-tracks', { name: playlist }, function(res) {
                            var tracks = (res && res.tracks) ? res.tracks : [];
                            if (!modalPlaylistTracks) return;
                            if (tracks.length === 0) {
                                modalPlaylistTracks.innerHTML = '<div class="text-center py-8 text-gray-500">No tracks in this playlist.</div>';
                            } else {
                                modalPlaylistTracks.innerHTML = tracks.map(function(t, i) {
                                    var art = (t && (t.albumArt || t.thumbnail)) || '';
                                    return '<div class="flex items-center gap-4 p-3 rounded-lg hover:bg-gray-800 transition">' +
                                        '<span class="text-gray-500 w-6">' + (i + 1) + '</span>' +
                                        '<img src="' + art + '" class="w-12 h-12 rounded object-cover" alt="" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||\'\';">' +
                                        '<div class="flex-1 min-w-0"><p class="font-medium truncate">' + (t.title || '') + '</p><p class="text-sm text-gray-400 truncate">' + (t.artist || '') + '</p></div>' +
                                        '<span class="text-sm text-gray-400">' + fmtTime(t.duration) + '</span>' +
                                        '<button type="button" class="playlist-track-play px-3 py-1 rounded bg-gray-700 hover:bg-accent-purple transition" data-url="' + (t.url || '').replace(/"/g, '&quot;') + '" title="Play"><i class="fas fa-play"></i></button>' +
                                        '</div>';
                                }).join('');
                                document.querySelectorAll('.playlist-track-play').forEach(function(btn) {
                                    btn.addEventListener('click', function(e) {
                                        e.stopPropagation();
                                        var url = btn.getAttribute('data-url');
                                        if (!url) return;
                                        socket.emit('play-track', { guildId: guildId, url: url }, function(res) {
                                            if (res && res.error) showToast(res.error, true);
                                            else { showToast('Playing: ' + (res && res.track ? res.track : 'track')); if (modalPlaylist) modalPlaylist.classList.add('hidden'); }
                                        });
                                    });
                                });
                            }
                        });
                    });
                });
                if (modalPlaylistPlayAll) {
                    modalPlaylistPlayAll.addEventListener('click', function() {
                        if (!currentModalPlaylistName || !socket || !guildId) return;
                        socket.emit('play-playlist', { guildId: guildId, name: currentModalPlaylistName }, function(res) {
                            if (res && res.error) showToast(res.error, true);
                            else {
                                showToast('Playing playlist (' + (res && res.count ? res.count : 0) + ' tracks)');
                                if (modalPlaylist) modalPlaylist.classList.add('hidden');
                                document.querySelector('.sidebar-item[data-view="queue"]').click();
                            }
                        });
                    });
                }
                if (modalPlaylistClose) modalPlaylistClose.addEventListener('click', function() { if (modalPlaylist) modalPlaylist.classList.add('hidden'); });
                if (modalPlaylist) modalPlaylist.addEventListener('click', function(e) { if (e.target === modalPlaylist) modalPlaylist.classList.add('hidden'); });

                var searchInput = document.getElementById('search-input');
                var searchBtn = document.getElementById('search-btn');
                var searchResults = document.getElementById('search-results');
                var searchLoading = document.getElementById('search-loading');
                var searchEmpty = document.getElementById('search-empty');

                function performSearch() {
                    var query = searchInput.value.trim();
                    if (!query || !socket || !guildId) return;
                    
                    searchResults.innerHTML = '';
                    searchEmpty.classList.add('hidden');
                    searchLoading.classList.remove('hidden');
                    
                    socket.emit('search', { query: query }, function(res) {
                        searchLoading.classList.add('hidden');
                        if (res && res.error) {
                            showToast(res.error, true);
                            return;
                        }
                        if (!res || !res.results || res.results.length === 0) {
                            searchEmpty.classList.remove('hidden');
                            return;
                        }
                        
                        searchResults.innerHTML = res.results.map(function(t) {
                            return '<div class="bg-gray-900 rounded-lg p-4 flex items-center gap-4 hover:bg-gray-800 transition">' +
                                '<img src="' + ((t && (t.albumArt || t.thumbnail)) || '') + '" class="w-16 h-16 rounded object-cover" alt="" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||\'\';">' +
                                '<div class="flex-1 min-w-0">' +
                                '<p class="font-medium truncate">' + (t.title || '') + '</p>' +
                                '<p class="text-sm text-gray-400 truncate">' + (t.artist || '') + '</p>' +
                                '</div>' +
                                '<div class="text-right text-sm text-gray-400">' + fmtTime(t.duration) + '</div>' +
                                '<button class="px-4 py-2 bg-accent-purple hover-accent-purple rounded-lg btn-play-result" data-url="' + (t.url || '') + '">' +
                                '<i class="fas fa-play"></i>' +
                                '</button>' +
                                '</div>';
                        }).join('');
                        
                        document.querySelectorAll('.btn-play-result').forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                var url = btn.getAttribute('data-url');
                                if (!url) return;
                                socket.emit('play-track', { guildId: guildId, url: url }, function(res) {
                                    if (res && res.error) showToast(res.error, true);
                                    else { showToast('Now playing: ' + (res && res.track ? res.track : 'track')); document.querySelector('.sidebar-item[data-view="queue"]').click(); }
                                });
                            });
                        });
                    });
                }
                
                if (searchBtn) searchBtn.addEventListener('click', performSearch);
                if (searchInput) {
                    searchInput.addEventListener('keypress', function(e) {
                        if (e.key === 'Enter') performSearch();
                    });
                }

            });
        })();
    </script>
    
</body>
</html>
