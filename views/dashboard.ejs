                            <div class="list-row" style="display:flex;align-items:center;gap:14px;padding:12px 12px;border-radius:10px;">
                                <img src="<%= s.albumArt||s.thumbnail||'' %>" style="width:48px;height:48px;border-radius:8px;object-fit:cover;background:var(--elevated);" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||'';">
                                <div style="flex:1;min-width:0;"><div style="font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= s.title||'—' %></div><div style="font-size:13px;color:var(--muted);"><%= s.artist||'—' %></div></div>
