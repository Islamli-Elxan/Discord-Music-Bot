                        </div>
                    </div>
                </div>

            </div><!-- end views -->
        </main>
    </div><!-- end flex wrapper -->


    <!-- FIXED BOTTOM PLAYER BAR -->
    <div style="position:fixed;bottom:0;left:240px;right:0;height:88px;background:rgba(10,10,15,.9);border-top:1px solid var(--border);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);display:flex;align-items:center;padding:0 28px;gap:20px;z-index:100;">
        <!-- Left: track info -->
        <div style="display:flex;align-items:center;gap:14px;width:240px;flex-shrink:0;">
            <img id="bar-artwork" src="" style="width:52px;height:52px;border-radius:10px;object-fit:cover;background:var(--elevated);" onerror="this.onerror=null;this.src=window.DASHBOARD_DEFAULT_ART||'';">
            <div style="min-width:0;">
                <div id="bar-title" style="font-size:14px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">—</div>
